{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/finance/v1/chat/stream.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/finance/v1/chat/stream",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
