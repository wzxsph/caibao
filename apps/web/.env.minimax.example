# Copy to .env.minimax, keep it local, and fill only server-side values.
NODE_ENV=development
API_PORT=18787
# Keep loopback for local runs. Docker Compose overrides this inside the container
# while publishing the host port on 127.0.0.1 only.
API_HOST=127.0.0.1
ANALYSIS_PROVIDER=minimax
MEDIA_IMPORT_ROOT=./media-import
ANALYSIS_WORK_ROOT=./.analysis-work
AUTHORIZED_DOUYIN_MANIFEST=./media-import/authorized-douyin/download-manifest.json
AUTHORIZED_MEDIA_ROOT=./.analysis-work/showcase-media
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_TEXT_MODEL=MiniMax-M2.7
# Optional: fill a vision-capable model that your account has verified.
# Empty falls back to transcript+OCR text analysis and does not send frames;
# this repository does not auto-probe model entitlements.
MINIMAX_MULTIMODAL_MODEL=
MINIMAX_TIMEOUT_MS=30000
MINIMAX_MAX_RETRIES=2

# Vercel public chat function. Keep every value except VITE_FINANCE_API_BASE_URL
# server-side; the GitHub Pages build receives only the public Vercel base URL.
CHAT_ALLOWED_ORIGIN=https://wzxsph.github.io
CHAT_PER_VIDEO_LIMIT=5
CHAT_DAILY_LIMIT=20
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
VITE_FINANCE_API_BASE_URL=

# Recommended timestamp authority: Volcengine big-model ASR flash API.
VOLC_ASR_ENABLED=true
VOLC_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLC_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
VOLC_ASR_API_KEY=
# Legacy console credentials; leave empty when VOLC_ASR_API_KEY is used.
VOLC_ASR_APP_ID=
VOLC_ASR_ACCESS_TOKEN=
VOLC_ASR_TIMEOUT_MS=120000
VOLC_ASR_MAX_AUDIO_MB=100
VOLC_ASR_MAX_BASE64_AUDIO_MB=20

# Optional dedicated OCR. Uses separate Volcengine OpenAPI AK/SK, not ARK_API_KEY.
VOLC_OCR_ENABLED=false
VOLC_OCR_ENDPOINT=https://visual.volcengineapi.com
VOLC_OCR_ACTION=OCRNormal
VOLC_OCR_VERSION=2020-08-26
VOLC_OCR_REGION=cn-north-1
VOLC_OCR_SERVICE=cv
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_OCR_TIMEOUT_MS=15000
VOLC_OCR_FILTER_THRESHOLD=80

# Optional creator-authorized metadata sync. Never put browser cookies here.
DOUYIN_OPEN_CLIENT_KEY=
DOUYIN_OPEN_CLIENT_SECRET=
DOUYIN_OPEN_BASE_URL=https://open.douyin.com

LIVE_PROVIDER_TESTS=false
