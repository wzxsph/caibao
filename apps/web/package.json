{
  "name": "@caibao/web",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "vite --host 127.0.0.1",
    "serve": "vite --host 127.0.0.1",
    "build": "vite build",
    "build-gp-pages": "vite build --mode gp_pages",
    "build-only": "vite build",
    "build-check": "run-p type-check \"build-only {@}\" --",
    "type-check": "vue-tsc --build --force",
    "type-check:server": "tsc -p tsconfig.server.json --noEmit",
    "test": "pnpm test:client && pnpm test:server",
    "test:client": "vitest run",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:watch": "vitest",
    "test:e2e": "pnpm build --mode e2e && playwright test",
    "dev:api": "tsx watch server/src/index.ts",
    "start:api": "tsx server/src/index.ts",
    "start:api:minimax": "CAIBAO_ENV_FILE=.env.minimax tsx server/src/index.ts",
    "start:api:doubao": "CAIBAO_ENV_FILE=.env.doubao tsx server/src/index.ts",
    "probe:douyin": "tsx server/src/cli/probe-douyin.ts",
    "prepare:authorized-media": "tsx server/src/cli/prepare-authorized-media.ts",
    "prepare:showcase-media": "tsx server/src/cli/prepare-showcase-media.ts",
    "generate:showcase-content": "tsx server/src/cli/generate-showcase-content.ts",
    "prepare:showcase": "pnpm prepare:showcase-media && pnpm generate:showcase-content",
    "stage:showcase-pages-media": "node scripts/stage-showcase-pages-media.mjs",
    "preview": "vite preview",
    "lint": "eslint  --fix  . --ext .vue,.js,.ts,.tsx,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src server e2e scripts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-router": "4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node20": "^20.1.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.28",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "5.3.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.6"
  }
}
