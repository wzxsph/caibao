# ─────────────────────────────────────────────────────────────────────────────
# caibao-pipeline-skill — environment template
# Copy this file to `.env` and fill the keys you have. Anything left blank
# disables the matching stage. The pipeline keeps running as long as the
# minimum viable path (parse → ASR → cue authoring) is satisfied; see
# README.md for "Provider modes" to pick the combination that fits you.
# ─────────────────────────────────────────────────────────────────────────────

# === Common pipeline settings ================================================
# Working directory for analysis jobs (frames, audio derivatives, intermediates).
PIPELINE_WORK_ROOT=./.pipeline-work

# Allow local FFmpeg/FFprobe on the PATH. Override if your binaries live elsewhere.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Switch the LLM provider used for semantic extraction + cue authoring.
# Allowed values: openai | mock
#   - openai:  real OpenAI-compatible endpoint (works for MiniMax, Doubao Ark, OpenAI).
#   - mock:    deterministic in-memory provider; ideal for offline smoke tests.
LLM_PROVIDER=mock

# Force a transcript input instead of running ASR. Set to a JSON path containing
# { fullText, segments } to skip the speech-recognition step.
TRANSCRIPT_OVERRIDE=

# Force an OCR input instead of calling the OCR provider. JSON path containing
# an OcrEvidence[] array.
OCR_OVERRIDE=

# ── Mode: openai-compatible LLM ==============================================
# Any service that follows the OpenAI Chat Completions tool-calling contract
# (MiniMax, Ark / Doubao, OpenAI, vLLM, Ollama via /v1, …) is supported.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M2.7
# Optional multimodal model name. Leave empty to fall back to text-only input
# (no frame images sent).
OPENAI_MULTIMODAL_MODEL=
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2

# ── Mode: Volcengine big-model ASR (timestamp authority) =====================
# Either fill VOLC_ASR_API_KEY (new-style) OR the legacy APP_ID + ACCESS_TOKEN.
VOLC_ASR_ENABLED=true
VOLC_ASR_ENDPOINT=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLC_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
VOLC_ASR_API_KEY=
VOLC_ASR_APP_ID=
VOLC_ASR_ACCESS_TOKEN=
VOLC_ASR_TIMEOUT_MS=120000
VOLC_ASR_MAX_AUDIO_MB=100
VOLC_ASR_MAX_BASE64_AUDIO_MB=20

# ── Mode: Volcengine OCR (optional; skips when blank) =======================
VOLC_OCR_ENABLED=false
VOLC_OCR_ENDPOINT=https://visual.volcengineapi.com
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_OCR_TIMEOUT_MS=15000